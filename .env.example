# Copy to .env (gitignored). SQLite file DB by default — zero setup.
DATABASE_URL="file:./dev.db"

# JWT secrets — CHANGE THESE. Any non-empty strings work for local/demo.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Points awarded per 1 PLN spent (demo economy)
POINTS_PER_PLN="1"
